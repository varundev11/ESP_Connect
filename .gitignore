# Frontend (Vite/React)
# -----------------------------
/Frontend/node_modules/
/Frontend/dist/
/Frontend/dist-ssr/
/Frontend/.vite/
/Frontend/.cache/
/Frontend/*.local
/Frontend/.env
/Frontend/.env.*
!/Frontend/.env.example

# Package manager / bundler logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
