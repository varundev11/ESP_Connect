# -----------------------------
# ESP-IDF / CMake build outputs
# -----------------------------
/build/

# Local generated project config (keep defaults under version control)
/sdkconfig
/sdkconfig.old
/sdkconfig.bak
!/sdkconfig.defaults

# Generic CMake/Ninja transient files (in case of out-of-tree builds)
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json
*.ninja
.ninja_*

# Flash/firmware artifacts
*.bin
*.elf
*.map
flasher_args.json
flash_args
flash_*.args

